<?xml version="1.0" encoding="utf-8"?>
<!--
    allowBackup=false oznacza że dane apki nie są kopiowane przez Auto Backup ani
    transferowane przy migracji urządzeń. Reguły poniżej dodatkowo wykluczają
    całą zawartość — defence in depth.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
